import java.util.Scanner;

public class CajeroAutomatico {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        // Datos de usuario (simulados)
        String usuarioCorrecto = "admin";
        String contrasenaCorrecta = "1234";

        String usuario, contrasena;

        double saldo = 1000000; // saldo inicial

        // LOGIN
        System.out.println("=== CAJERO AUTOMÁTICO ===");
        System.out.print("Ingrese usuario: ");
        usuario = sc.nextLine();

        System.out.print("Ingrese contraseña: ");
        contrasena = sc.nextLine();

        if (!usuario.equals(usuarioCorrecto) || !contrasena.equals(contrasenaCorrecta)) {
            System.out.println("Credenciales incorrectas");
            return;
        }

        int opcion;

        do {
            System.out.println("\n--- MENÚ ---");
            System.out.println("1. Consultar saldo");
            System.out.println("2. Retirar");
            System.out.println("3. Transferir");
            System.out.println("4. Salir");
            System.out.print("Seleccione una opción: ");

            opcion = sc.nextInt();

            switch (opcion) {

                case 1:
                    // Consultar saldo
                    System.out.println("Su saldo es: $" + saldo);
                    break;

                case 2:
                    // Retirar dinero
                    System.out.print("Ingrese monto a retirar: ");
                    double retiro = sc.nextDouble();

                    if (retiro > saldo) {
                        System.out.println("Saldo insuficiente");
                    } else {
                        saldo -= retiro;
                        System.out.println("Retiro exitoso");
                    }
                    break;

                case 3:
                    // Transferir dinero
                    System.out.print("Ingrese monto a transferir: ");
                    double transferencia = sc.nextDouble();

                    if (transferencia > saldo) {
                        System.out.println("Saldo insuficiente");
                    } else {
                        saldo -= transferencia;
                        System.out.println("Transferencia exitosa");
                    }
                    break;

                case 4:
                    System.out.println("Gracias por usar el cajero");
                    break;

                default:
                    System.out.println("Opción inválida");
            }

        } while (opcion != 4);

        sc.close();
    }
}

//Codigo de un cajero automatico basico, con opciones para consultar saldo, retirar y transferir dinero.